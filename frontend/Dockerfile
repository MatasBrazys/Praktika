# frontend/Dockerfile — production
# Two-stage: build with Node, serve with Nginx.
# VITE_API_URL is intentionally empty — frontend uses relative /api paths.
# Nginx proxies /api → backend internally.

FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80 443