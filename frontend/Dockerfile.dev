# frontend/Dockerfile.dev — development only
# Runs Vite dev server with hot reload.
# Source code is mounted via volume — no rebuild needed on changes.

FROM node:22-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci
# Source mounted at runtime via docker-compose volume
EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]