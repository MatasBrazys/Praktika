# Database
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name
DATABASE_URL_DOCKER=postgresql://your_db_user:your_db_password@db:5432/your_db_name

# CORS — comma separated origins
CORS_ORIGINS=https://yourdomain.com

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# LDAP
LDAP_ORGANISATION=Your Organisation
LDAP_DOMAIN=company.local
LDAP_ADMIN_PASSWORD=your_ldap_admin_password
LDAP_ADMIN_GROUP=FormAdmin
LDAP_USER_GROUP=FormUser
LDAP_CONFIRMER_GROUP=FormConfirmer

# Email SMTP
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=IT Portal <noreply@yourcompany.com>
EMAIL_ENABLED=true